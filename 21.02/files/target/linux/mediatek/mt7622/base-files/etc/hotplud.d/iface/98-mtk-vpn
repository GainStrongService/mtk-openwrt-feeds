proto=`uci -q get network.$INTERFACE.proto`

if [ "$proto" = pptp ]; then
	if [ "$ACTION" = ifup ]; then
		echo 0 > /sys/kernel/debug/hnat/hook_toggle
	elif [ "$ACTION" = ifdown ]; then
		echo 1 > /sys/kernel/debug/hnat/hook_toggle
	fi
fi
