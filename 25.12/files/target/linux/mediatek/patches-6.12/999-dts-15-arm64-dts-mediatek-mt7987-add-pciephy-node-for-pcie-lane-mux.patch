---
[v1] arm64: dts: mediatek: mt7987: add pciephy node for pcie lane mux

Add PCIe PHY node with lane mux support for flexible PCIe topology
configuration. Supports both 1-port 2-lanes and 2-port 1-lane modes
for PCIe bandwidth allocation flexibility.

Requirements:
- Enable CONFIG_PHY_MTK_PCIE in kernel config
- Apply kernel patch: 999-phy-01-mediatek-phy-mtk-pcie-add-mt7987-pcie-lane-mux-support.patch
---
v1: Initial PCIe PHY node with lane mux support for flexible 1x2 or 2x1
    lane topology configuration.
---

--- a/arch/arm64/boot/dts/mediatek/mt7987.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7987.dtsi
@@ -661,10 +661,23 @@
 			reg = <0 0x15104800 0 0x400>;
 		};
 
+		pciephy: phy@11e4a000 {
+			compatible = "mediatek,mt7987-pcie-phy";
+			reg = <0 0x11e4a000 0 0x100>;
+			reg-names = "sif";
+			#phy-cells = <1>;
+			mediatek,syscon-type = <&topmisc 0x110>;
+			/* Optional: specify lane mode configuration */
+			/* mediatek,1port-2lane; */
+			/* mediatek,2port-1lane; */
+		};
+
 		pcie0: pcie@11280000 {
 			compatible = "mediatek,mt7987-pcie",
 				     "mediatek,mt8192-pcie";
 			device_type = "pci";
+			phys = <&pciephy PHY_TYPE_PCIE>;
+			phy-names = "pcie-phy";
 			#address-cells = <3>;
 			#size-cells = <2>;
 			reg = <0 0x11280000 0 0x2000>;
