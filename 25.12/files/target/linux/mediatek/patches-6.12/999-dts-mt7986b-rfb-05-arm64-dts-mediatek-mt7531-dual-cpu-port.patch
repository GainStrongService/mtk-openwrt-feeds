---
[v1] arm64: dts: mediatek: add dual-cpu-port support in DSA for MT7986b-RFB

Add dual-cpu-port support in DSA for MT7986b-RFB.
---
v1: Add dual-cpu-port support in DSA for MT7986b-RFB.
---

From 6657f02a966672a639bd7d419e32ff303618f9a3 Mon Sep 17 00:00:00 2001
From: "neal.yen" <neal.yen@mediatek.com>
Date: Thu, 28 May 2026 15:11:02 +0800
Subject: [PATCH] arm64: dts: mediatek: add dual-cpu-port support in DSA for MT7986b-RFB

---
 .../mt7986b-rfb-dsa-dual-cpu-port.dts         | 198 ++++++++++++++++++
 1 file changed, 198 insertions(+)
 create mode 100644 arch/arm64/boot/dts/mediatek/mt7986b-rfb-dsa-dual-cpu-port.dts

diff --git a/arch/arm64/boot/dts/mediatek/mt7986b-rfb-dsa-dual-cpu-port.dts b/arch/arm64/boot/dts/mediatek/mt7986b-rfb-dsa-dual-cpu-port.dts
new file mode 100644
index 0000000..650c40e
--- /dev/null
+++ b/arch/arm64/boot/dts/mediatek/mt7986b-rfb-dsa-dual-cpu-port.dts
@@ -0,0 +1,198 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+/*
+ * Copyright (C) 2026 MediaTek Inc.
+ * Author: Neal.Yen <neal.yen@mediatek.com>
+ */
+
+/dts-v1/;
+#include "mt7986b.dtsi"
+#include "mt7986-pinctrl.dtsi"
+/ {
+	model = "MediaTek MT7986b RFB";
+	chassis-type = "embedded";
+	compatible = "mediatek,mt7986b-rfb-dsa-dual-cpu-port", "mediatek,mt7986b";
+
+	aliases {
+		serial0 = &uart0;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+	};
+
+	gpio-keys {
+		compatible = "gpio-keys";
+
+		reset {
+			label = "reset";
+			linux,code = <KEY_RESTART>;
+			gpios = <&pio 9 GPIO_ACTIVE_LOW>;
+			debounce-interval = <10>;
+		};
+
+		wps {
+			label = "wps";
+			linux,code = <KEY_WPS_BUTTON>;
+			gpios = <&pio 10 GPIO_ACTIVE_LOW>;
+			debounce-interval = <10>;
+		};
+	};
+
+	memory@40000000 {
+		device_type = "memory";
+		reg = <0 0x40000000 0 0x40000000>;
+	};
+};
+
+&crypto {
+	status = "okay";
+};
+
+&eth {
+	status = "okay";
+
+	gmac0: mac@0 {
+		compatible = "mediatek,eth-mac";
+		reg = <0>;
+		phy-mode = "2500base-x";
+
+		fixed-link {
+			speed = <2500>;
+			full-duplex;
+			pause;
+		};
+	};
+
+	gmac1: mac@1 {
+		compatible = "mediatek,eth-mac";
+		reg = <1>;
+		phy-mode = "2500base-x";
+
+		fixed-link {
+			speed = <2500>;
+			full-duplex;
+			pause;
+		};
+	};
+
+	mdio: mdio-bus {
+		#address-cells = <1>;
+		#size-cells = <0>;
+
+		reset-gpios = <&pio 6 1>;
+		reset-delay-us = <600>;
+		reset-post-delay-us = <20000>;
+
+		switch@0 {
+			compatible = "mediatek,mt7531";
+			reg = <31>;
+			reset-gpios = <&pio 5 0>;
+
+			ports {
+				#address-cells = <1>;
+				#size-cells = <0>;
+
+				port@0 {
+					reg = <0>;
+					label = "lan0";
+					cpu-port = <6>;
+				};
+
+				port@1 {
+					reg = <1>;
+					label = "lan1";
+					cpu-port = <6>;
+				};
+
+				port@2 {
+					reg = <2>;
+					label = "lan2";
+					cpu-port = <6>;
+				};
+
+				port@3 {
+					reg = <3>;
+					label = "lan3";
+					cpu-port = <6>;
+				};
+
+				port@4 {
+					reg = <4>;
+					label = "wan";
+					cpu-port = <5>;
+				};
+
+				port@5 {
+					reg = <5>;
+					label = "cpu";
+					ethernet = <&gmac1>;
+					phy-mode = "2500base-x";
+
+					fixed-link {
+						speed = <2500>;
+						full-duplex;
+						pause;
+					};
+				};
+
+				port@6 {
+					reg = <6>;
+					label = "cpu";
+					ethernet = <&gmac0>;
+					phy-mode = "2500base-x";
+
+					fixed-link {
+						speed = <2500>;
+						full-duplex;
+						pause;
+					};
+				};
+			};
+		};
+	};
+};
+
+&spi0 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&spi_nand_pins>;
+	cs-gpios = <0>, <0>;
+	status = "okay";
+
+	spi_nand: flash@0 {
+		compatible = "spi-nand";
+		reg = <0>;
+		spi-max-frequency = <52000000>;
+		spi-tx-bus-width = <4>;
+		spi-rx-bus-width = <4>;
+	};
+};
+
+&spi1 {
+	pinctrl-names = "default";
+	pinctrl-0 = <&spic_pins>;
+	cs-gpios = <0>, <0>;
+	status = "okay";
+};
+
+&ssusb {
+	status = "okay";
+};
+
+&uart0 {
+	status = "okay";
+};
+
+&usb_phy {
+	status = "okay";
+};
+
+&watchdog {
+	status = "okay";
+};
+
+&wifi {
+	status = "okay";
+	pinctrl-names = "default", "dbdc";
+	pinctrl-0 = <&wf_2g_5g_pins>;
+	pinctrl-1 = <&wf_dbdc_pins>;
+};
-- 
2.45.2

