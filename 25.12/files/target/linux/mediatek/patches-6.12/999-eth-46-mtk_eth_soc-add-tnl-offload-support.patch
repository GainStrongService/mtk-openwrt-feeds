---
[v2] mtk_eth_soc: Support NPU tunnel offload feature

Support MediaTek Ethernet driver to receive decap'ed tunnel packets. The driver
requires the system to provide an implementation of mtk_get_tnl_dev to route the
hardware-decap'ed tunnel packets to correct network interface.

In addition, add corresponding TPORT definitions to support tunnel encapsulation or
encrypted tunnel encapsulation feature so that the packet can route through the
NETSYS hardware to offload packet encryption and encapsulation.

---
v1: Add tunnel offload support
v2: Add encrypted tunnel offload support
---

--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
@@ -353,6 +353,9 @@ static const char * const mtk_clks_sourc
 	"top_netsys_warp_sel",
 };
 
+struct net_device *(*mtk_get_tnl_dev)(u8 tops_crsn) = NULL;
+EXPORT_SYMBOL(mtk_get_tnl_dev);
+
 void mtk_w32(struct mtk_eth *eth, u32 val, unsigned reg)
 {
 	__raw_writel(val, eth->base + reg);
@@ -2767,13 +2770,14 @@ static int mtk_poll_rx(struct napi_struc
 	int done = 0, bytes = 0;
 	dma_addr_t dma_addr = DMA_MAPPING_ERROR;
 	int ppe_idx = 0;
+	u8 tops_crsn = 0;
 
 	if (unlikely(!ring))
 		goto rx_done;
 
 	while (done < budget) {
 		unsigned int pktlen, *rxdcsum;
-		struct net_device *netdev;
+		struct net_device *netdev = NULL;
 		u32 hash, reason;
 		int mac = 0;
 
@@ -2808,7 +2812,15 @@ static int mtk_poll_rx(struct napi_struc
 			     !eth->netdev[mac]))
 			goto release_desc;
 
-		netdev = eth->netdev[mac];
+		tops_crsn = RX_DMA_GET_TOPS_CRSN(trxd.rxd6);
+		if (mtk_get_tnl_dev && tops_crsn) {
+			netdev = mtk_get_tnl_dev(tops_crsn);
+			if (IS_ERR(netdev))
+				netdev = NULL;
+		}
+
+		if (!netdev)
+			netdev = eth->netdev[mac];
 		ppe_idx = eth->mac[mac]->ppe_idx;
 
 		if (unlikely(test_bit(MTK_RESETTING, &eth->state)))
--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.h
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.h
@@ -469,6 +469,8 @@
 #define TPORT_QDMA			1
 #define TPORT_EIP197			2
 #define TPORT_EIP197_QDMA		3
+#define TPORT_NPU_QDMA			5
+#define TPORT_NPU_EIP197_QDMA		9
 #define TX_DMA_TPORT_MASK       GENMASK(3, 0)
 #define TX_DMA_FPORT_SHIFT_V2	8
 #define TX_DMA_FPORT_MASK_V2	0xf
@@ -2022,6 +2024,9 @@ static inline bool mtk_interface_mode_is
 	}
 }
 
+/* tunnel offload related */
+extern struct net_device *(*mtk_get_tnl_dev)(u8 tops_crsn);
+
 /* read the hardware status register */
 void mtk_stats_update_mac(struct mtk_mac *mac);
 
