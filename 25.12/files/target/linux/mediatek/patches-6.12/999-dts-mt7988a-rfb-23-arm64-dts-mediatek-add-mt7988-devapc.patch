From fd279bc9eebf710e1930cc5a588d29ce8b500f69 Mon Sep 17 00:00:00 2001
From: Tim-cy Yang <Tim-cy.Yang@mediatek.com>
Date: Fri, 20 Mar 2026 16:50:42 +0800
Subject: [PATCH] arm64: dts: mediatek: add mt7988 device APC

---
 arch/arm64/boot/dts/mediatek/mt7988a.dtsi | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/arch/arm64/boot/dts/mediatek/mt7988a.dtsi b/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
index 3cf1bb793fc2..7af909565b31 100644
--- a/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
@@ -1408,6 +1408,12 @@ crypto: crypto@15600000 {
 			status = "okay";
 			eth = <&eth>;
 		};
+
+		devapc: devapc@1a110000 {
+			compatible = "mediatek,mt7988-devapc";
+			reg = <0 0x1a110000 0 0x1000>;
+			interrupts = <GIC_SPI 174 IRQ_TYPE_LEVEL_HIGH>;
+		};
 	};
 
 	thermal-zones {
-- 
2.45.2

