[v1] arm64: dts: mediatek: add mt7987 cpufreq cooling device

Enable cpufreq cooling for MT7987 CPU thermal zone to allow thermal
throttling via CPU frequency scaling.
---
v1: Move openwrt-master files to openwrt-25.12 branch after OpenWrt official
    25.12 branch release.
---

diff --git a/arch/arm64/boot/dts/mediatek/mt7987.dtsi b/arch/arm64/boot/dts/mediatek/mt7987.dtsi
index 953a28f..8333899 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7987.dtsi
@@ -64,6 +64,7 @@ cpu0: cpu@0 {
 				 <&apmixedsys CLK_APMIXED_ARM_LL>;
 			clock-names = "cpu", "intermediate", "armpll";
 			operating-points-v2 = <&cluster0_opp>;
+			#cooling-cells = <2>;
 		};
 
 		cpu1: cpu@1 {
@@ -275,6 +276,19 @@ cpu_trip_crit: crit {
 					hysteresis = <2000>;
 					type = "critical";
 				};
+
+				cpu_trip_active_hot: active-hot {
+					temperature = <117000>;
+					hysteresis = <2000>;
+					type = "active";
+				};
+			};
+
+			cooling-maps {
+				cpu-active-hot {
+					cooling-device = <&cpu0 THERMAL_NO_LIMIT THERMAL_NO_LIMIT>;
+					trip = <&cpu_trip_active_hot>;
+				};
 			};
 		};
 
