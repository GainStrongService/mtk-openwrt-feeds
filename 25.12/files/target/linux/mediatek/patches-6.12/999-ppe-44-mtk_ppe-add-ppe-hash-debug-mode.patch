---
[v1] net: ethernet: mtk_ppe: add PPE hash_mode debugfs

Add a "hash_mode" debugfs node to switch the PPE FOE table hash between
the normal 5-tuple hash and a simple single-field hash.
---
v1: Add PPE hash_mode debugfs.
---

From 4a1f9c2d0e5b6a7c8d9e0f1a2b3c4d5e6f708192 Mon Sep 17 00:00:00 2001
From: "chak-kei.lam" <chak-kei.lam@mediatek.com>
Date: Fri, 17 Jul 2026 11:00:00 +0800
Subject: [PATCH] net: ethernet: mtk_ppe: add PPE hash_mode debugfs

Add a "hash_mode" debugfs node (NETSYSv2 or greater) to choose how the
PPE indexes the FOE table, either the normal 5-tuple hash or a simple
hash on a single tuple field:

	0  normal (5-tuple, default)
	1  source port
	2  IPv4 source IP
	3  IPv6 source IP
	4  destination port
	5  IPv4 destination IP
	6  IPv6 destination IP

Usage:
	# show the current mode and the list
	cat /sys/kernel/debug/mtk_ppe/hash_mode
	# select a mode, e.g. IPv4 source IP
	echo 2 > /sys/kernel/debug/mtk_ppe/hash_mode
---
 drivers/net/ethernet/mediatek/mtk_ppe.c         | 50 ++++++++++++++-
 drivers/net/ethernet/mediatek/mtk_ppe.h         |  1 +
 drivers/net/ethernet/mediatek/mtk_ppe_debugfs.c | 85 +++++++++++++++++++++++++
 drivers/net/ethernet/mediatek/mtk_ppe_regs.h    | 12 ++++
 4 files changed, 145 insertions(+), 3 deletions(-)

diff --git a/drivers/net/ethernet/mediatek/mtk_ppe.c b/drivers/net/ethernet/mediatek/mtk_ppe.c
index fea919f..9180a33 100644
--- a/drivers/net/ethernet/mediatek/mtk_ppe.c
+++ b/drivers/net/ethernet/mediatek/mtk_ppe.c
@@ -307,7 +307,7 @@ static void mtk_ppe_cache_enable(struct mtk_ppe *ppe, bool enable)
 		enable * MTK_PPE_CACHE_CTL_EN);
 }
 
-static u32 mtk_ppe_hash_entry(struct mtk_eth *eth, struct mtk_foe_entry *e)
+static u32 mtk_ppe_hash_normal_key(struct mtk_eth *eth, struct mtk_foe_entry *e)
 {
 	u32 hv1, hv2, hv3;
 	u32 hash;
@@ -342,6 +342,48 @@ static u32 mtk_ppe_hash_entry(struct mtk_eth *eth, struct mtk_foe_entry *e)
 	hash ^= hv1 ^ hv2 ^ hv3;
 	hash ^= hash >> 16;
 	hash <<= (ffs(eth->soc->hash_offset) - 1);
+
+	return hash;
+}
+
+static u32 mtk_ppe_hash_entry(struct mtk_ppe *ppe, struct mtk_foe_entry *e)
+{
+	struct mtk_eth *eth = ppe->eth;
+	bool ipv6 = mtk_get_ib1_pkt_type(eth, e->ib1) >
+		    MTK_PPE_PKT_TYPE_IPV4_DSLITE;
+	u8 mode = ppe->hash_mode;
+	u32 hash;
+
+	switch (mode) {
+	case MTK_PPE_HASH_DBG_NORMAL:
+		hash = mtk_ppe_hash_normal_key(eth, e);
+		break;
+	case MTK_PPE_HASH_DBG_SPORT:
+		hash = ipv6 ? e->ipv6.src_port : e->ipv4.orig.src_port;
+		break;
+	case MTK_PPE_HASH_DBG_DPORT:
+		hash = ipv6 ? e->ipv6.dest_port : e->ipv4.orig.dest_port;
+		break;
+	/*
+	 * SIP/DIP simple hash is only defined for the matching L3 type. For the
+	 * other type we deliberately return 0 here.
+	 */
+	case MTK_PPE_HASH_DBG_IP4_SIP:
+		hash = ipv6 ? 0 : e->ipv4.orig.src_ip;
+		break;
+	case MTK_PPE_HASH_DBG_IP4_DIP:
+		hash = ipv6 ? 0 : e->ipv4.orig.dest_ip;
+		break;
+	case MTK_PPE_HASH_DBG_IP6_SIP:
+		hash = ipv6 ? e->ipv6.src_ip[3] : 0;
+		break;
+	case MTK_PPE_HASH_DBG_IP6_DIP:
+		hash = ipv6 ? e->ipv6.dest_ip[3] : 0;
+		break;
+	default:
+		return 0;
+	}
+
 	hash &= MTK_PPE_ENTRIES - 1;
 
 	return hash;
@@ -1055,7 +1097,7 @@ int mtk_foe_entry_commit(struct mtk_ppe *ppe, struct mtk_flow_entry *entry)
 	if (type == MTK_PPE_PKT_TYPE_BRIDGE)
 		return mtk_foe_entry_commit_l2(ppe, entry);
 
-	hash = mtk_ppe_hash_entry(ppe->eth, &entry->data);
+	hash = mtk_ppe_hash_entry(ppe, &entry->data);
 	entry->hash = 0xffff;
 	spin_lock_bh(&ppe_lock);
 	hlist_add_head(&entry->list, &ppe->foe_flow[hash / soc->hash_offset]);
@@ -1372,7 +1414,9 @@ void mtk_ppe_start(struct mtk_ppe *ppe)
 	      FIELD_PREP(MTK_PPE_TB_CFG_ENTRY_NUM,
 			 MTK_PPE_ENTRIES_SHIFT);
 	if (mtk_is_netsys_v2_or_greater(ppe->eth))
-		val |= MTK_PPE_TB_CFG_INFO_SEL;
+		val |= MTK_PPE_TB_CFG_INFO_SEL |
+		       FIELD_PREP(MTK_PPE_TB_CFG_HASH_DBG,
+				  ppe->hash_mode);
 	if (mtk_is_netsys_v3_or_greater(ppe->eth))
 		val |= MTK_PPE_TB_CFG_KEEP_DSCP_ECN_EN |
 		       MTK_PPE_TB_CFG_IS_SP_TAG_EN;
diff --git a/drivers/net/ethernet/mediatek/mtk_ppe.h b/drivers/net/ethernet/mediatek/mtk_ppe.h
index 63f59eb..193104a 100644
--- a/drivers/net/ethernet/mediatek/mtk_ppe.h
+++ b/drivers/net/ethernet/mediatek/mtk_ppe.h
@@ -372,6 +372,7 @@ struct mtk_ppe {
 	int version;
 	char dirname[5];
 	bool accounting;
+	u8 hash_mode;
 
 	void *foe_table;
 	dma_addr_t foe_phys;
diff --git a/drivers/net/ethernet/mediatek/mtk_ppe_debugfs.c b/drivers/net/ethernet/mediatek/mtk_ppe_debugfs.c
index 9197988..e18bf52 100644
--- a/drivers/net/ethernet/mediatek/mtk_ppe_debugfs.c
+++ b/drivers/net/ethernet/mediatek/mtk_ppe_debugfs.c
@@ -6,6 +6,7 @@
 #include <linux/inet.h>
 
 #include <net/ipv6.h>
+#include <net/netfilter/nf_flow_table.h>
 
 #include "mtk_eth_soc.h"
 #include "mtk_ppe_regs.h"
@@ -470,6 +471,87 @@ static const struct file_operations mtk_ppe_internal_debugfs_l4s_fops = {
 	.release = single_release,
 };
 
+static const char * const mtk_ppe_hash_mode_str[] = {
+	[MTK_PPE_HASH_DBG_NORMAL]   = "Normal",
+	[MTK_PPE_HASH_DBG_SPORT]    = "Source port[15:0]",
+	[MTK_PPE_HASH_DBG_IP4_SIP]  = "IPv4 source IP[15:0]",
+	[MTK_PPE_HASH_DBG_IP6_SIP]  = "IPv6 source IP[15:0]",
+	[MTK_PPE_HASH_DBG_DPORT]    = "Destination port[15:0]",
+	[MTK_PPE_HASH_DBG_IP4_DIP]  = "IPv4 destination IP[15:0]",
+	[MTK_PPE_HASH_DBG_IP6_DIP]  = "IPv6 destination IP[15:0]",
+};
+
+static int
+mtk_ppe_internal_debugfs_show_hash(struct seq_file *m, void *private)
+{
+	struct mtk_eth *eth = m->private;
+	u8 mode = eth->ppe[0] ? eth->ppe[0]->hash_mode : 0;
+	unsigned int i;
+
+	seq_printf(m, "PPE hash mode = %d (%s)\n", mode,
+		   mtk_ppe_hash_mode_str[mode]);
+	seq_puts(m, "[hash mode]\n");
+	for (i = 0; i < ARRAY_SIZE(mtk_ppe_hash_mode_str); i++)
+		seq_printf(m, "\t%u\t%s\n", i, mtk_ppe_hash_mode_str[i]);
+
+	return 0;
+}
+
+static int
+mtk_ppe_internal_debugfs_open_hash(struct inode *inode, struct file *file)
+{
+	return single_open(file, mtk_ppe_internal_debugfs_show_hash,
+			   inode->i_private);
+}
+
+static ssize_t
+mtk_ppe_internal_debugfs_write_hash(struct file *file, const char __user *buffer,
+				    size_t count, loff_t *data)
+{
+	struct seq_file *m = file->private_data;
+	struct mtk_eth *eth = m->private;
+	char buf[8] = {0};
+	u32 mode;
+	int i;
+
+	if (count >= sizeof(buf) || copy_from_user(buf, buffer, count))
+		return -EFAULT;
+
+	if (kstrtouint(buf, 0, &mode))
+		return -EINVAL;
+
+	if (mode >= MTK_PPE_HASH_DBG_MAX) {
+		pr_err("Invalid hash mode %u\n", mode);
+		mtk_ppe_internal_debugfs_show_hash(m, NULL);
+		return -EINVAL;
+	}
+
+	for (i = 0; i < eth->soc->ppe_num; i++) {
+		if (!eth->ppe[i])
+			continue;
+
+		eth->ppe[i]->hash_mode = mode;
+		ppe_m32(eth->ppe[i], MTK_PPE_TB_CFG, MTK_PPE_TB_CFG_HASH_DBG,
+			FIELD_PREP(MTK_PPE_TB_CFG_HASH_DBG, mode));
+	}
+
+	/* flush all offloaded flows so they are re-learned under the new mode */
+	nf_flow_table_cleanup(NULL);
+
+	pr_info("PPE hash mode set to %u (%s)\n", mode,
+		mtk_ppe_hash_mode_str[mode]);
+
+	return count;
+}
+
+static const struct file_operations mtk_ppe_internal_debugfs_hash_fops = {
+	.open = mtk_ppe_internal_debugfs_open_hash,
+	.read = seq_read,
+	.write = mtk_ppe_internal_debugfs_write_hash,
+	.llseek = seq_lseek,
+	.release = single_release,
+};
+
 static int
 mtk_ppe_internal_debugfs_foe_all_show(struct seq_file *m, void *private)
 {
@@ -615,6 +697,9 @@ int mtk_ppe_internal_debugfs_init(struct mtk_eth *eth)
 			    &mtk_ppe_internal_debugfs_qos_fops);
 	debugfs_create_file("debug_level", S_IRUGO, root, eth,
 			    &mtk_ppe_internal_debugfs_level_fops);
+	if (mtk_is_netsys_v2_or_greater(eth))
+		debugfs_create_file("hash_mode", S_IRUGO, root, eth,
+				    &mtk_ppe_internal_debugfs_hash_fops);
 	/* only mt7988 can support l4s through tops */
 	if (eth->soc->caps == MT7988_CAPS)
 		debugfs_create_file("l4s_toggle", S_IRUGO, root, eth,
diff --git a/drivers/net/ethernet/mediatek/mtk_ppe_regs.h b/drivers/net/ethernet/mediatek/mtk_ppe_regs.h
index b5854cb..de10904 100644
--- a/drivers/net/ethernet/mediatek/mtk_ppe_regs.h
+++ b/drivers/net/ethernet/mediatek/mtk_ppe_regs.h
@@ -66,6 +66,7 @@
 #define MTK_PPE_TB_CFG_SCAN_MODE		GENMASK(17, 16)
 #define MTK_PPE_TB_CFG_HASH_DEBUG		GENMASK(19, 18)
 #define MTK_PPE_TB_CFG_INFO_SEL			BIT(20)
+#define MTK_PPE_TB_CFG_HASH_DBG			GENMASK(23, 21)
 #define MTK_PPE_TB_TICK_SEL			BIT(24)
 #define MTK_PPE_TB_CFG_KEEP_DSCP_ECN_EN		BIT(25)
 #define MTK_PPE_TB_CFG_IS_SP_TAG_EN		BIT(26)
@@ -93,6 +94,17 @@ enum {
 	MTK_PPE_SEARCH_MISS_ACTION_FORWARD_BUILD = 3,
 };
 
+enum {
+	MTK_PPE_HASH_DBG_NORMAL,
+	MTK_PPE_HASH_DBG_SPORT,		/* source port[15:0] */
+	MTK_PPE_HASH_DBG_IP4_SIP,	/* IPv4 source IP[15:0] */
+	MTK_PPE_HASH_DBG_IP6_SIP,	/* IPv6 source IP[15:0] */
+	MTK_PPE_HASH_DBG_DPORT,		/* destination port[15:0] */
+	MTK_PPE_HASH_DBG_IP4_DIP,	/* IPv4 destination IP[15:0] */
+	MTK_PPE_HASH_DBG_IP6_DIP,	/* IPv6 destination IP[15:0] */
+	MTK_PPE_HASH_DBG_MAX
+};
+
 #define MTK_PPE_TB_BASE				0x220
 
 #define MTK_PPE_TB_USED				0x224
