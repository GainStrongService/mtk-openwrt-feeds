---
[v1] arm64: dts: mediatek: Add MT7987 emi to handle memory access violation

Add emi node for MT7987 to handle the situation when a memory access
violates the access permission control (APC) configured by system.
---
v1: Add MT7987 emi to handle memory access violation
---

diff --git a/arch/arm64/boot/dts/mediatek/mt7987.dtsi b/arch/arm64/boot/dts/mediatek/mt7987.dtsi
index e76a0bb4b825..3af7da645ef1 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7987.dtsi
@@ -810,6 +810,13 @@ devapc: devapc@1a110000 {
 			reg = <0 0x1a110000 0 0x1000>;
 			interrupts = <GIC_SPI 174 IRQ_TYPE_LEVEL_HIGH>;
 		};
+
+		emi: emi@10219000  {
+			compatible = "mediatek,mt7987-emi",
+				     "mediatek,mt7986-emi";
+			reg = <0 0x10219000 0 0x1000>;
+			interrupts = <GIC_SPI 111 IRQ_TYPE_LEVEL_HIGH>;
+		};
 	};
 
 	netsys: soc_netsys {
-- 
2.45.2

