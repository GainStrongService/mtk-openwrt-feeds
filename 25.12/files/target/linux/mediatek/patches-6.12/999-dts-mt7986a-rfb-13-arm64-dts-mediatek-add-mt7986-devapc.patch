---
[v1] arm64: dts: mediatek: Add MT7986 device APC

Add devie APC for MT7986 to handle the situation when a transaction
violates the access permission control (APC) configured by system.
---
v1: Add MT7986 device APC
---

diff --git a/arch/arm64/boot/dts/mediatek/mt7986a.dtsi b/arch/arm64/boot/dts/mediatek/mt7986a.dtsi
index 270176911a99..121cc4cf1419 100644
--- a/arch/arm64/boot/dts/mediatek/mt7986a.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7986a.dtsi
@@ -642,6 +642,12 @@ wifi: wifi@18000000 {
 				     <GIC_SPI 216 IRQ_TYPE_LEVEL_HIGH>;
 			memory-region = <&wmcpu_emi>;
 		};
+
+		devapc: devapc@1a110000 {
+			compatible = "mediatek,mt7986-devapc";
+			reg = <0 0x1a110000 0 0x1000>;
+			interrupts = <GIC_SPI 174 IRQ_TYPE_LEVEL_HIGH>;
+		};
 	};
 
 	thermal-zones {
-- 
2.45.2

