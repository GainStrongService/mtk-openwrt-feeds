---
[v1] arm64: dts: mediatek: Add MT7981 emi to handle memory access violation

Add emi node for MT7981 to handle the situation when a memory access
violates the access permission control (APC) configured by system.
---
v1: Add MT7981 emi to handle memory access violation
---

diff --git a/arch/arm64/boot/dts/mediatek/mt7981b.dtsi b/arch/arm64/boot/dts/mediatek/mt7981b.dtsi
index 29325e65e6c5..288b8c591202 100644
--- a/arch/arm64/boot/dts/mediatek/mt7981b.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7981b.dtsi
@@ -744,6 +744,13 @@ devapc: devapc@1a110000 {
 			reg = <0 0x1a110000 0 0x1000>;
 			interrupts = <GIC_SPI 174 IRQ_TYPE_LEVEL_HIGH>;
 		};
+
+		emi: emi@10219000  {
+			compatible = "mediatek,mt7981-emi",
+				     "mediatek,mt7986-emi";
+			reg = <0 0x10219000 0 0x1000>;
+			interrupts = <GIC_SPI 111 IRQ_TYPE_LEVEL_HIGH>;
+		};
 	};
 
 	thermal-zones {
-- 
2.45.2

