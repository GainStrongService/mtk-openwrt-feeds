---
[v1] arm64: dts: mediatek: add mt7987 multiple thermal zones

Add separate thermal zones for each sensor to allow independent monitoring and
configuration with per-sensor trip points and cooling maps.
---
v1: Move openwrt-master files to openwrt-25.12 branch after OpenWrt official
    25.12 branch release.
---

diff --git a/arch/arm64/boot/dts/mediatek/mt7987.dtsi b/arch/arm64/boot/dts/mediatek/mt7987.dtsi
index f036128..953a28f 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7987.dtsi
@@ -12,6 +12,7 @@
 #include <dt-bindings/pinctrl/mt65xx.h>
 #include <dt-bindings/gpio/gpio.h>
 #include <dt-bindings/thermal/thermal.h>
+#include <dt-bindings/thermal/mediatek,lvts-thermal.h>
 #include <dt-bindings/reset/mediatek,mt7987-resets.h>
 #include <dt-bindings/regulator/richtek,rt5190a-regulator.h>
 
@@ -266,7 +267,7 @@ thermal-zones {
 		cpu_thermal: cpu-thermal {
 			polling-delay-passive = <1000>;
 			polling-delay = <1000>;
-			thermal-sensors = <&lvts 0>;
+			thermal-sensors = <&lvts MT7987_CPU>;
 
 			trips {
 				cpu_trip_crit: crit {
@@ -276,6 +277,20 @@ cpu_trip_crit: crit {
 				};
 			};
 		};
+
+		eth2p5g_thermal: eth2p5g-thermal {
+			polling-delay-passive = <1000>;
+			polling-delay = <1000>;
+			thermal-sensors = <&lvts MT7987_ETH2P5G>;
+
+			trips {
+				eth2p5g_trip_crit: crit {
+					temperature = <125000>;
+					hysteresis = <2000>;
+					type = "critical";
+				};
+			};
+		};
 	};
 
 	timer {
-- 
