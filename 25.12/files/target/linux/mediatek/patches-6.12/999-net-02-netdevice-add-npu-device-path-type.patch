---
[v2] netdevice: Add tunnel offload device path type

Support tunnel hardware offload by extending enum net_device_path_type with
tunnel related definitions and extending struct net_device_path with essential
tunnel related parameters.
The "dst" is used to find xfrm_state for supporting tunnl over IPSec.

---
v1: Add L2TP flow offload support for NPU
v2: Support tunnel over IPSec hardware offload
---

--- a/include/linux/netdevice.h
+++ b/include/linux/netdevice.h
@@ -840,6 +840,7 @@ enum net_device_path_type {
 	DEV_PATH_DSA,
 	DEV_PATH_MACVLAN,
 	DEV_PATH_MTK_WDMA,
+	DEV_PATH_L2TP,
 };
 
 struct net_device_path {
@@ -873,9 +874,30 @@ struct net_device_path {
 			u8 amsdu;
 			u8 tid;
 		} mtk_wdma;
+		struct {
+			u8 h_source[ETH_ALEN];
+			u8 h_dest[ETH_ALEN];
+			union nf_inet_addr sip;
+			union nf_inet_addr dip;
+			u16 sport;
+			u16 dport;
+			union {
+				struct {
+					u16 ul_tid;
+					u16 dl_tid;
+					u16 ul_sid;
+					u16 dl_sid;
+				} l2tp;
+				/* Extend other tunnel here */
+			};
+			/* Info used to find xfrm_state for IPSec (encap direction) */
+			struct dst_entry *dst;
+		} tunnel;
 	};
 };
 
+extern int (*mtk_flow_tnl_offloadable)(const struct net_device_path *path);
+
 #define NET_DEVICE_PATH_STACK_MAX	5
 #define NET_DEVICE_PATH_VLAN_MAX	2
 
--- a/net/core/dev.c
+++ b/net/core/dev.c
@@ -164,6 +164,9 @@
 #include "devmem.h"
 #include "net-sysfs.h"
 
+int (*mtk_flow_tnl_offloadable)(const struct net_device_path *path);
+EXPORT_SYMBOL(mtk_flow_tnl_offloadable);
+
 static DEFINE_SPINLOCK(ptype_lock);
 struct list_head ptype_base[PTYPE_HASH_SIZE] __read_mostly;
 
