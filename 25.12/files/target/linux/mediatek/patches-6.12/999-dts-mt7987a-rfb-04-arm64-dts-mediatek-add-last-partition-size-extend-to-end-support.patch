---
[v1] arm64: dts: mediatek: mt7987: Add mtd partition extend to end support
Add "mtd-extend-to-end" in mt7987 spim nand/nor related dts.
Partition with "mtd-extend-to-end" will extend to the end of
parent partiton and note that the size of partition in reg must be
set to 0 like reg = <0x0200000 0x0>.
---
v1: Add mtd partition extend to end support.
---

--- a/arch/arm64/boot/dts/mediatek/mt7987-spim-nand-nmbm.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987-spim-nand-nmbm.dtso
@@ -67,8 +67,9 @@
 
 					partition@780000 {
 						label = "ubi";
-						reg = <0x780000 0x7080000>;
+						reg = <0x780000 0x0>;
 						compatible = "linux,ubi";
+						mtd-extend-to-end;
 
 						volumes {
 							ubi_rootfs: ubi-volume-fit {
--- a/arch/arm64/boot/dts/mediatek/mt7987-spim-nand.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987-spim-nand.dtso
@@ -31,8 +31,9 @@
 
