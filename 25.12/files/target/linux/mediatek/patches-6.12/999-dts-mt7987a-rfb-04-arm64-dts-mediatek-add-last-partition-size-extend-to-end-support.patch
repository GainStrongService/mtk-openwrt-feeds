-						reg = <0x0200000 0x7e00000>;
+						reg = <0x0200000 0x0>;
 						compatible = "linux,ubi";
+						mtd-extend-to-end;
 
 						volumes {
 							ubi-volume-ubootenv {
--- a/arch/arm64/boot/dts/mediatek/mt7987-spim-nor.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987-spim-nor.dtso
@@ -45,7 +45,8 @@
 				};
 				nor_rootdisk: partition@2D0000 {
 					label = "firmware";
-					reg = <0x2D0000 0x1D30000>;
+					reg = <0x2D0000 0x0>;
+					mtd-extend-to-end;
 				};
 			};
 		};
