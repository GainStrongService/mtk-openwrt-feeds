---
[v1] arm64: dts: mt7988: add optee device node

Add OP-TEE (Open Portable Trusted Execution Environment) firmware node for MT7988A
to enable secure world communication via SMC (Secure Monitor Call) method.
---
v1: Move openwrt-master files to openwrt-25.12 branch after OpenWrt official
    25.12 branch release.
---

--- a/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
@@ -16,6 +16,14 @@
 	#address-cells = <2>;
 	#size-cells = <2>;

+       firmware {
+                optee {
+                        status = "okay";
+                        method = "smc";
+                        compatible = "linaro,optee-tz";
+                };
+        };
+
 	cci: cci {
 		compatible = "mediatek,mt8183-cci";
 		clocks = <&mcusys CLK_MCU_BUS_DIV_SEL>,

