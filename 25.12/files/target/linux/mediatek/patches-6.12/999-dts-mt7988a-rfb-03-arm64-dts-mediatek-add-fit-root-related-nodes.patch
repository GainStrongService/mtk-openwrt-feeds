---
[v1] arm64: dts: mediatek: add fit root related nodes

Add FIT (Flattened Image Tree) boot support to MT7988A RFB device tree.

---
v1: Move openwrt-master files to openwrt-25.12 branch after OpenWrt official
    25.12 branch release.
---

--- a/arch/arm64/boot/dts/mediatek/mt7988a-rfb.dts
+++ b/arch/arm64/boot/dts/mediatek/mt7988a-rfb.dts
@@ -19,7 +19,8 @@
 	chosen {
 		bootargs = "console=ttyS0,115200n1 \
 			    earlycon=uart8250,mmio32,0x11000000 \
-			    pci=pcie_bus_perf";
+			    pci=pcie_bus_perf ubi.block=0,firmware root=/dev/fit0 \
+			    rootwait";
 	};
 
 	memory@40000000 {
