---
[v1] arm64: dts: mediatek: mt7987a: Add mtd partition extend to end support
Add "mtd-extend-to-end" in mt7987a bananapi r4 lite spim nand/nor
related dts. Partition with "mtd-extend-to-end" will extend to the end of
parent partiton and note that the size of partition in reg must be
set to 0 like reg = <0x0200000 0x0>.
---
v1: Add mtd partition extend to end support.
---

--- a/arch/arm64/boot/dts/mediatek/mt7987a-bananapi-bpi-r4-mini-nand-nmbm.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987a-bananapi-bpi-r4-mini-nand-nmbm.dtso
@@ -55,8 +55,9 @@
 			};
 			partition@780000 {
 				label = "ubi";
-				reg = <0x780000 0x7080000>;
+				reg = <0x780000 0x0>;
 				compatible = "linux,ubi";
+				mtd-extend-to-end;
 				volumes {
 					ubi_rootfs: ubi-volume-fit {
 						volname = "firmware";
--- a/arch/arm64/boot/dts/mediatek/mt7987a-bananapi-bpi-r4-mini-nand.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987a-bananapi-bpi-r4-mini-nand.dtso
@@ -31,8 +31,9 @@
 
 			partition@200000 {
 				label = "ubi";
-				reg = <0x0200000 0xfe00000>;
+				reg = <0x0200000 0x0>;
 				compatible = "linux,ubi";
+				mtd-extend-to-end;
 
 				volumes {
 					ubi-volume-ubootenv {
