---
[v1] arm64: dts: mt7987: add pcie wifi reset support

Add WiFi hardware reset GPIO control for PCIe with proper timing delays to
ensure reliable WiFi module initialization. Supports GPIO38 reset control with
configurable assert and deassert delays.

---
v1: Initial WiFi hardware reset GPIO support in PCIE device tree using GPIO38
    for WiFi reset control during PCIe probe process.
---


--- a/arch/arm64/boot/dts/mediatek/mt7987a-rfb.dts
+++ b/arch/arm64/boot/dts/mediatek/mt7987a-rfb.dts
@@ -87,3 +87,11 @@
 	pwms = <&pwm 0 50000 0>;
 	status = "disabled";
 };
+
+&pcie0 {
+	wifi-reset-gpios = <&pio 38 GPIO_ACTIVE_LOW>;
+	wifi-reset-msleep = <100>;
+	wifi-deassert-msleep = <500>;
+	status = "okay";
+};
+
