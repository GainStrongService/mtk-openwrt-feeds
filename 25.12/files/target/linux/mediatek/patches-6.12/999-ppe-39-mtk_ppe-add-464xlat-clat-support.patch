+static bool
+mtk_is_464xlat_offloadable(struct mtk_eth *eth, struct mtk_foe_entry *entry)
+{
+	struct nf_conntrack_tuple_hash *h;
+	struct nf_conntrack_tuple tuple;
+	struct nf_conn *ct;
+	u32 ct_mark, pkt_type;
+
+	pkt_type = mtk_get_ib1_pkt_type(eth, entry->ib1);
+
+	if (pkt_type == MTK_PPE_PKT_TYPE_464XLAT_46 &&
+	    !mtk_is_netsys_v3_or_greater(eth))
+		return false;
+
+	mtk_foe_to_ct_tuple(eth, entry, &tuple);
+
+	h = nf_conntrack_find_get(&init_net, &nf_ct_zone_dflt, &tuple);
+	if (!h)
+		return true;
+
+	ct = nf_ct_tuplehash_to_ctrack(h);
+	ct_mark = ct->mark & 0xff;
+	nf_ct_put(ct);
+
+	/* Skip hardware offload if the conntrack entry was marked before
+	 * 464XLAT translation, indicating this flow should not be offloaded.
+	 */
+	if (ct_mark == MTK_PPE_EXCEPTION_TAG)
+		return false;
+
+	return true;
+}
