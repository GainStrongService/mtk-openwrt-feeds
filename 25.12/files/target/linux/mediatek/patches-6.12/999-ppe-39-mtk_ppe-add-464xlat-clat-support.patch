+static struct mtk_foe_entry *
+mtk_find_tuple_in_ppe(struct mtk_eth *eth, int *ppe_index, bool is_v6,
+		      struct mtk_flow_data *data)
+{
+	struct mtk_ppe *ppe;
+	struct mtk_foe_entry *hwe, *target = NULL;
+	int state, pkt_type, found = 0;
+	int i, j;
+	u32 src_ip[4] = {0}, dest_ip[4] = {0};
+	u16 src_port, dest_port;
+
+	if (!is_v6) {
+		src_ip[0] = be32_to_cpu(data->v4.src_addr);
+		dest_ip[0] = be32_to_cpu(data->v4.dst_addr);
+	} else {
+		for (i = 0; i < 4; i++) {
+			src_ip[i] = be32_to_cpu(data->v6.src_addr.s6_addr32[i]);
+			dest_ip[i] = be32_to_cpu(data->v6.dst_addr.s6_addr32[i]);
+		}
+	}
+
+	src_port = be16_to_cpu(data->src_port);
+	dest_port = be16_to_cpu(data->dst_port);
+
+	for (i = 0; i < eth->soc->ppe_num; i++) {
+		ppe = eth->ppe[i];
+
+		for (j = 0; j < MTK_PPE_ENTRIES; j++) {
+			hwe = mtk_foe_get_entry(ppe, j);
+			state = FIELD_GET(MTK_FOE_IB1_STATE, hwe->ib1);
+			pkt_type = mtk_get_ib1_pkt_type(eth, hwe->ib1);
+
+			if (state != MTK_FOE_STATE_UNBIND)
+				continue;
+
+			if (!is_v6) {
+				/* find IPV4_HNAPT entry for 4to6 xlat */
+				if (pkt_type != MTK_PPE_PKT_TYPE_IPV4_HNAPT)
+					continue;
+
+				if (dest_ip[0] == hwe->ipv4.orig.dest_ip &&
+				    src_port == hwe->ipv4.orig.src_port &&
+				    dest_port == hwe->ipv4.orig.dest_port) {
+					found++;
+					target = hwe;
+					*ppe_index = i;
+				}
+			} else {
+				/* find IPV6_5T_ROUTE entry for 6to4 xlat */
+				if (pkt_type != MTK_PPE_PKT_TYPE_IPV6_ROUTE_5T)
+					continue;
+
+				if (!memcmp(&hwe->ipv6.src_ip, src_ip, sizeof(hwe->ipv6.src_ip)) &&
+				    src_port == hwe->ipv6.src_port &&
+				    dest_port == hwe->ipv6.dest_port) {
+					found++;
+					target = hwe;
+					*ppe_index = i;
+				}
+			}
+		}
+	}
+
+	return (found == 1) ? target : NULL;
+}
