+static int mtk_ppe_internal_debugfs_read_464xlat(struct seq_file *m, void *private)
+{
+	struct mtk_eth *eth = m->private;
+
+	if (!eth->xlat464)
+		return -EINVAL;
+
+	if (mtk_is_xlat464_enabled())
+		seq_printf(m, "464xlat acceleration is enabled with prefix = %pI6\n",
+			   &eth->xlat464->prefix);
+	else
+		seq_puts(m, "464xlat acceleration is disabled\n");
+
+	return 0;
+}
+
+static int mtk_ppe_internal_debugfs_open_464xlat(struct inode *inode, struct file *file)
+{
+	return single_open(file, mtk_ppe_internal_debugfs_read_464xlat,
+			   inode->i_private);
+}
+
+static ssize_t mtk_ppe_internal_debugfs_write_464xlat(struct file *file,
+						      const char __user *buf,
+						      size_t length, loff_t *offset)
+{
+	struct seq_file *m = file->private_data;
+	struct mtk_eth *eth = m->private;
+	char line[64] = {0};
+	char addr[INET6_ADDRSTRLEN];
+	int enable, ret, i;
+
+	if (!eth->xlat464)
+		return -EINVAL;
+
+	if (length >= sizeof(line))
+		return -EINVAL;
+
+	if (copy_from_user(line, buf, length))
+		return -EFAULT;
+
+	line[length] = '\0';
+
+	ret = sscanf(line, "%1d %45s", &enable, addr);
+	if (ret < 1)
+		return -EINVAL;
+
+	if (enable) {
+		if (ret != 2)
+			return -EINVAL;
+
+		if (!in6_pton(addr, -1, (u8 *)&eth->xlat464->prefix, -1, NULL))
+			return -EINVAL;
+	}
+
+	for (i = 0; i < eth->soc->ppe_num; i++) {
+		if (!eth->ppe[i])
+			continue;
+
+		ppe_m32(eth->ppe[i], MTK_PPE_FLOW_CFG, MTK_PPE_FLOW_CFG_464XLAT,
+			enable ? MTK_PPE_FLOW_CFG_464XLAT : 0);
+	}
+
+	if (enable)
+		static_branch_enable(&mtk_xlat464_enabled);
+	else
+		static_branch_disable(&mtk_xlat464_enabled);
+
+	return length;
+}
+
