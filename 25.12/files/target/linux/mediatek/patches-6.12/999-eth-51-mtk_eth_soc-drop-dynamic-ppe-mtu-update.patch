---
[v1] net: ethernet: mtk_eth_soc: drop the dynamic PPE MTU update

Drop the dynamic PPE MTU update tied to netdev MTU changes.
 
The HW offload path is designed around the default 1.5K MTU
setting, and altering it at runtime is outside the expected
system configuration. Keeping the PPE at its default avoids
unexpected behavior on offloaded flows.
---
v1: Drop the dynamic PPE MTU update.
---

From 90844a3eab52a1040de13e7f39a65ae24e7f3fed Mon Sep 17 00:00:00 2001
From: Mason Chang <mason-cw.chang@mediatek.com>
Date: Fri, 29 May 2026 13:59:05 +0800
Subject: [PATCH] net: ethernet: mtk_eth_soc: drop the dynamic
PPE MTU update

Drop the dynamic PPE MTU update tied to netdev MTU changes.
 
The HW offload path is designed around the default 1.5K MTU
setting, and altering it at runtime is outside the expected
system configuration. Keeping the PPE at its default avoids
unexpected behavior on offloaded flows.
---
 mtk_eth_soc.c | 11 ++---------
 1 file changed, 2 insertions(+), 9 deletions(-)

diff --git a/drivers/net/ethernet/mediatek/mtk_eth_soc.c b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
index 42e28be..eb030b1 100644
--- a/drivers/net/ethernet/mediatek/mtk_eth_soc.c
+++ b/drivers/net/ethernet/mediatek/mtk_eth_soc.c
@@ -4621,7 +4621,7 @@ static int mtk_open(struct net_device *dev)
 	struct mtk_mac *mac = netdev_priv(dev);
 	struct mtk_eth *eth = mac->hw;
 	struct mtk_mac *target_mac;
-	int i, err, ppe_num, mtu;
+	int i, err, ppe_num;
 
 	ppe_num = eth->soc->ppe_num;
 
@@ -4668,10 +4668,6 @@ static int mtk_open(struct net_device *dev)
 			mtk_gdm_config(eth, target_mac->id, gdm_config);
 		}
 
-		mtu = mtk_max_gmac_mtu(eth);
-		for (i = 0; i < ARRAY_SIZE(eth->ppe); i++)
-			mtk_ppe_update_mtu(eth->ppe[i], mtu);
-
 		if (MTK_HAS_CAPS(eth->soc->caps, MTK_HWTSTAMP))
 			mtk_ptp_clock_init(eth);
 
@@ -5733,16 +5729,13 @@ static int mtk_change_mtu(struct net_device *dev, int new_mtu)
 {
 	struct mtk_mac *mac = netdev_priv(dev);
 	struct mtk_eth *eth = mac->hw;
-	int max_mtu, i, length;
+	int max_mtu, length;
 	u32 rx_buf_len;
 
 	WRITE_ONCE(dev->mtu, new_mtu);
 	rx_buf_len = eth->rx_buf_len;
 
 	max_mtu = mtk_max_gmac_mtu(eth);
-	for (i = 0; i < ARRAY_SIZE(eth->ppe); i++)
-		mtk_ppe_update_mtu(eth->ppe[i], max_mtu);
-
 	length = max_mtu + MTK_RX_ETH_HLEN;
 
 	if (rcu_access_pointer(eth->prog) &&
-- 
