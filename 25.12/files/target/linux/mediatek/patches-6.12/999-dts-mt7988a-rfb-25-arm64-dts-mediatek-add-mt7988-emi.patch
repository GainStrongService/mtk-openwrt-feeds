---
[v1] arm64: dts: mediatek: Add MT7988 emi to handle memory access violation

Add emi node for MT7988 to handle the situation when a memory access
violates the access permission control (APC) configured by system.
---
v1: Add MT7988 emi to handle memory access violation
---

diff --git a/arch/arm64/boot/dts/mediatek/mt7988a.dtsi b/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
index b4cdd21dd264..37b0420aa520 100644
--- a/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7988a.dtsi
@@ -1414,6 +1414,13 @@ devapc: devapc@1a110000 {
 			reg = <0 0x1a110000 0 0x1000>;
 			interrupts = <GIC_SPI 174 IRQ_TYPE_LEVEL_HIGH>;
 		};
+
+		emi: emi@10219000  {
+			compatible = "mediatek,mt7988-emi",
+				     "mediatek,mt7986-emi";
+			reg = <0 0x10219000 0 0x1000>;
+			interrupts = <GIC_SPI 111 IRQ_TYPE_LEVEL_HIGH>;
+		};
 	};
 
 	thermal-zones {
-- 
2.45.2

