---
[v1] arm64: dts: mediatek: Add MT7981 device APC

Add devie APC for MT7981 to handle the situation when a transaction
violates the access permission control (APC) configured by system.
---
v1: Add MT7981 device APC
---

diff --git a/arch/arm64/boot/dts/mediatek/mt7981b.dtsi b/arch/arm64/boot/dts/mediatek/mt7981b.dtsi
index 804cb2e2b1e5..d321b412083e 100644
--- a/arch/arm64/boot/dts/mediatek/mt7981b.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7981b.dtsi
@@ -739,6 +739,12 @@ wifi: wifi@18000000 {
 			memory-region = <&wmcpu_emi>;
 			status = "disabled";
 		};
+
+		devapc: devapc@1a110000 {
+			compatible = "mediatek,mt7981-devapc";
+			reg = <0 0x1a110000 0 0x1000>;
+			interrupts = <GIC_SPI 174 IRQ_TYPE_LEVEL_HIGH>;
+		};
 	};
 
 	thermal-zones {
-- 
2.45.2

