+    char bk_file[S_BUFFER_LEN];
+    char cmd[BUFFER_LEN];
+
+    snprintf(bk_file, sizeof(bk_file), "%s_bk", CERT_PEM);
+    if (!file_exists(bk_file)) {
+        snprintf(cmd, sizeof(cmd), "cp %s %s", CERT_PEM, bk_file);
+        system(cmd);
+    }
+
+    snprintf(bk_file, sizeof(bk_file), "%s_bk", CERT_CRT);
+    if (!file_exists(bk_file)) {
