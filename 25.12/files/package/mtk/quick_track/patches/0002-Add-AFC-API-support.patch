 }
+
+
+static int afcd_get_info_handler(struct packet_wrapper *req, struct packet_wrapper *resp) {
+    struct interface_info* wlan = NULL;
+    struct tlv_hdr *tlv;
+    int freq = 0, channel = 0, cfi = 0, cfi_freq;
+    char response[S_BUFFER_LEN];
+    char cmd[S_BUFFER_LEN];
+    FILE *chan_info;
+
+    wlan = get_wireless_interface_info(BAND_6GHZ, AFC_IDENTIFIER);
+    if (!wlan)
+        goto done;
+    snprintf(cmd, sizeof(cmd), "iw %s info | grep channel", wlan->ifname);
+    chan_info = popen(cmd, "r");
+    memset(response, 0, sizeof(response));
+    fgets(response, sizeof(response), chan_info);
+    sscanf(response, " channel %d (%d MHz), width: %*d MHz, center1: %d MHz", &channel, &freq, &cfi_freq);
+    cfi = (cfi_freq - 5955) / 5 + 1;
+
+done:
+    fill_wrapper_message_hdr(resp, API_CMD_RESPONSE, req->hdr.seq);
+    fill_wrapper_tlv_byte(resp, TLV_STATUS, TLV_VALUE_STATUS_OK);
+    fill_wrapper_tlv_bytes(resp, TLV_MESSAGE, strlen(TLV_VALUE_OK), TLV_VALUE_OK);
+    snprintf(response, sizeof(response), "%d", freq);
+    fill_wrapper_tlv_bytes(resp, TLV_AFC_OPER_FREQ, strlen(response), response);
+    snprintf(response, sizeof(response), "%d", channel);
+    fill_wrapper_tlv_bytes(resp, TLV_AFC_OPER_CHANNEL, strlen(response), response);
+    snprintf(response, sizeof(response), "%d", cfi);
+    fill_wrapper_tlv_bytes(resp, TLV_AFC_CENTER_FREQ_INDEX, strlen(response), response);
+    return 0;
+}
+
+
+#define ELLIPSE 0
+#define LINEARPOLYGON 1
+#define RADIALPOLYGON 2
+static int generate_afc_hostapd_config(char *output, int output_size, struct packet_wrapper *wrapper, struct interface_info* wlanp) {
+    struct tlv_to_config_name *cfg = NULL;
+    struct tlv_hdr *tlv, *tmp;
+    char buffer[S_BUFFER_LEN], cfg_item[2*BUFFER_LEN], mac_addr[64];
+    int afc_list_size = sizeof(afc_maps) / sizeof(struct tlv_to_config_name);
+    int i;
+    int offset = 0;
+    int lpi_type = 1;
+
+    /* hard code generic hostapd config for 6GHz */
+    offset += snprintf(output, output_size - offset, "afcd_sock=%s\n", get_afcd_path());
+    offset += snprintf(output + offset, output_size - offset, "ctrl_interface=%s\nctrl_interface_group=0\ninterface=%s\n", HAPD_CTRL_PATH_DEFAULT, wlanp->ifname);
+    offset += snprintf(output + offset, output_size - offset, "country_code=US\nchannel=37\nhw_mode=a\nieee80211ax=1\nieee80211be=1\n");
+    offset += snprintf(output + offset, output_size - offset, "ieee80211d=1\nhe_bss_color=1\nbeacon_prot=1\nrnr=1\n");
+    offset += snprintf(output + offset, output_size - offset, "he_6ghz_reg_pwr_type=%d\nsku_idx=0\n", lpi_type);
+
+    for (i = 0; i < wrapper->tlv_num; i++) {
+        tlv = wrapper->tlv[i];
+        memset(buffer, 0, sizeof(buffer));
+        memset(cfg_item, 0, sizeof(cfg_item));
+
+        switch(tlv->id) {
+        case TLV_AFC_RULE_SET_ID:
+            char buffer2[S_BUFFER_LEN];
+
+            memcpy(buffer, tlv->value, tlv->len);
+
+            memset(buffer2, 0, sizeof(buffer2));
+            tmp = find_wrapper_tlv_by_id(wrapper, TLV_AFC_CERT_ID);
+            memcpy(buffer2, tmp->value, tmp->len);
+
+            snprintf(cfg_item, sizeof(cfg_item), "afc_cert_ids=%s:%s\n", buffer, buffer2);
+            strcat(output, cfg_item);
+            break;
+        case TLV_AFC_LOCATION_GEO_AREA:
+            int geo_area;
+
+            memcpy(buffer, tlv->value, tlv->len);
+            snprintf(cfg_item, sizeof(cfg_item), "afc_location_type=%s\n", buffer);
+            strcat(output, cfg_item);
+
+            geo_area = atoi(buffer);
+            memset(cfg_item, 0, sizeof(cfg_item));
+            memset(buffer, 0, sizeof(buffer));
+            if (geo_area == ELLIPSE) {
+                tmp = find_wrapper_tlv_by_id(wrapper, TLV_AFC_ELLIPSE_CENTER);
+                if (!tmp)
+                    continue;
+                memcpy(buffer, tmp->value, tmp->len);
+                buffer[sizeof(buffer) - 1] = '\0';
+                for (int j = 0; j < strlen(buffer); j++) {
+                    if (buffer[j] == ',') {
+                        buffer[j] = ':';
+                        break;
+                    }
+                }
+                snprintf(cfg_item, sizeof(cfg_item), "afc_linear_polygon=%s\n", buffer);
+                strcat(output, cfg_item);
+            } else if (geo_area == LINEARPOLYGON) {
+                tmp = find_wrapper_tlv_by_id(wrapper, TLV_AFC_LINEARPOLY_BOUNDARY);
+                if (!tmp)
+                    continue;
+                memcpy(buffer, tmp->value, tmp->len);
+                buffer[sizeof(buffer) - 1] = '\0';
+                for (int j = 0; j < strlen(buffer); j++) {
+                    if (buffer[j] == ',')
+                        buffer[j] = ':';
+                    else if (buffer[j] == ' ')
+                        buffer[j] = ',';
+                }
+                snprintf(cfg_item, sizeof(cfg_item), "afc_linear_polygon=%s\n", buffer);
+                strcat(output, cfg_item);
+            } else if (geo_area == RADIALPOLYGON) {
+                tmp = find_wrapper_tlv_by_id(wrapper, TLV_AFC_RADIALPOLY_CENTER);
+                if (!tmp)
+                    continue;
+                memcpy(buffer, tmp->value, tmp->len);
+                buffer[sizeof(buffer) - 1] = '\0';
+                for (int j = 0; j < strlen(buffer); j++) {
+                    if (buffer[j] == ',') {
+                        buffer [j] = ':';
+                        break;
+                    }
+                }
+                snprintf(cfg_item, sizeof(cfg_item), "afc_linear_polygon=%s\n", buffer);
+                strcat(output, cfg_item);
+
+                memset(cfg_item, 0, sizeof(cfg_item));
+                memset(buffer, 0, sizeof(buffer));
+                tmp = find_wrapper_tlv_by_id(wrapper, TLV_AFC_RADIALPOLY_BOUNDARY);
+                if (!tmp)
+                    continue;
+                memcpy(buffer, tmp->value, tmp->len);
+                buffer[S_BUFFER_LEN - 1] = '\0';
+                for (int j = 0; j < strlen(buffer); j++) {
+                    if (buffer[j] == ',')
+                        buffer[j] = ':';
+                    else if (buffer[j] == ' ')
+                        buffer[j] = ',';
+                }
+                snprintf(cfg_item, sizeof(cfg_item), "afc_radial_polygon=%s\n", buffer);
+                strcat(output, cfg_item);
+            }
+            break;
+        case TLV_AFC_FREQ_RANGE:
+            memcpy(buffer, tlv->value, tlv->len);
+            for (int j = 0; j < strlen(buffer); j++) {
+                if (buffer[j] == ',')
+                    buffer[j] = ':';
+                else if (buffer[j] == ' ')
+                    buffer[j] = ',';
+            }
+            snprintf(cfg_item, sizeof(cfg_item), "afc_freq_range=%s\n", buffer);
+            strcat(output, cfg_item);
+            break;
+        case TLV_AFC_GLOBAL_OPCL:
+            memcpy(buffer, tlv->value, tlv->len);
+            for (int j = 0; j < strlen(buffer); j++) {
+                if (buffer[j] == ' ')
+                    buffer[j] = ',';
+            }
+            snprintf(cfg_item, sizeof(cfg_item), "afc_op_class=%s\n", buffer);
+            strcat(output, cfg_item);
+            break;
+        case TLV_AFC_BANDWIDTH:
+            int central_channel;
+            int op_class;
+
+            memcpy(buffer, tlv->value, tlv->len);
+            switch(atoi(buffer)) {
+            case 1:
+                central_channel = 35;
+                op_class = 132;
+                break;
+            case 2:
+                central_channel = 39;
+                op_class = 133;
+                break;
+            case 3:
+                central_channel = 47;
+                op_class = 134;
+                break;
+            case 4:
+                central_channel = 31;
+                op_class = 137;
+                break;
+            case 0:
+            default:
+                central_channel = 37;
+                op_class = 131;
+                break;
+            }
+            snprintf(cfg_item, sizeof(cfg_item), "op_class=%d\n", op_class);
+            strcat(output, cfg_item);
+            /* hardcode he center channel for EHT bw 320 */
+            if (atoi(buffer) == 4)
+                snprintf(cfg_item, sizeof(cfg_item), "he_oper_centr_freq_seg0_idx=0\n");
+            else
+                snprintf(cfg_item, sizeof(cfg_item), "he_oper_centr_freq_seg0_idx=%d\n", central_channel);
+            strcat(output, cfg_item);
+            snprintf(cfg_item, sizeof(cfg_item), "eht_oper_centr_freq_seg0_idx=%d\n", central_channel);
+            strcat(output, cfg_item);
+            break;
+        case TLV_AFC_SECURITY_TYPE:
+            memcpy(buffer, tlv->value, tlv->len);
+            if (atoi(buffer) == 0) {
+                snprintf(cfg_item, sizeof(cfg_item), "wpa=2\nwpa_key_mgmt=SAE\nrsn_pairwise=CCMP GCMP-256\nsae_pwe=2\n");
+                strcat(output, cfg_item);
+                snprintf(cfg_item, sizeof(cfg_item), "ieee80211w=2\nsae_require_mfp=1\nsae_groups=15 16 17 18 19 20 21\n");
+                strcat(output, cfg_item);
+            }
+            break;
+        default:
+            cfg = find_generic_tlv_config(tlv->id, afc_maps, afc_list_size);
+            if (!cfg) {
+                indigo_logger(LOG_LEVEL_INFO, "Unknown AP configuration name: TLV ID 0x%04x", tlv->id);
+                continue;
+            }
+            memcpy(buffer, tlv->value, tlv->len);
+            sprintf(cfg_item, "%s=%s\n", cfg->config_name, buffer);
+            strcat(output, cfg_item);
+            break;
+        }
+    }
+    tlv = find_wrapper_tlv_by_id(wrapper, TLV_AFC_BANDWIDTH);
+    if (!tlv) {
+        snprintf(cfg_item, sizeof(cfg_item), "op_class=131\nhe_oper_centr_freq_seg0_idx=37\neht_oper_centr_freq_seg0_idx=37\n");
+        strcat(output, cfg_item);
+    }
+
+    memset(mac_addr, 0, sizeof(mac_addr));
+    get_mac_address(mac_addr, sizeof(mac_addr), wlanp->ifname);
+    sprintf(buffer, "bssid=%s\n", mac_addr);
+    strcat(output, buffer);
+
+    return strlen(output);
+}
+
+
+static int afcd_configure_handler(struct packet_wrapper *req, struct packet_wrapper *resp) {
+    struct interface_info* wlan = NULL;
+    struct bss_identifier_info bss_info;
+    struct tlv_hdr *tlv;
+    char *message = TLV_VALUE_OK;
+    char buffer[L_BUFFER_LEN], url[S_BUFFER_LEN] = {0};
+    int i = 0, len = 0;
+    int status = TLV_VALUE_STATUS_OK;
+    int swap_hostapd = 0;
+
+    for (i = 0; i < req->tlv_num; i++) {
+        struct indigo_tlv *i_tlv;
+        char tlv_value[64];
+        i_tlv = get_tlv_by_id(req->tlv[i]->id);
+        if (i_tlv) {
+            memset(tlv_value, 0, sizeof(tlv_value));
+            memcpy(tlv_value, req->tlv[i]->value, req->tlv[i]->len);
+            indigo_logger(LOG_LEVEL_DEBUG, "TLV: %s - %s", i_tlv->name, tlv_value);
+        }
+    }
+
+    bss_info.band = BAND_6GHZ;
+    bss_info.identifier = AFC_IDENTIFIER;
+    wlan = get_wireless_interface_info(bss_info.band, bss_info.identifier);
+    if (!wlan) {
+        wlan = assign_wireless_interface_info(&bss_info);
+        if (!wlan)
+            goto done;
+    }
+    memset(buffer, 0, sizeof(buffer));
+    len = generate_afc_hostapd_config(buffer, sizeof(buffer), req, wlan);
+    if (len) {
+        if (wlan->link_conf_file[0])
+            write_file(wlan->link_conf_file, buffer, len);
+        else
+            write_file(wlan->hapd_conf_file, buffer, len);
+    }
+    show_wireless_interface_info();
+
+    indigo_logger(LOG_LEVEL_INFO, "send_afc_req: killall afcd");
+    system("killall afcd");
+
+    tlv = find_wrapper_tlv_by_id(req, TLV_AFC_CA_CERT);
+    if (!tlv)
+        goto done;
+
+    memset(buffer, 0, sizeof(buffer));
+    memcpy(buffer, tlv->value, tlv->len);
+    if (strlen(buffer)) {
+        char cmd[BUFFER_LEN];
+
+        snprintf(cmd, sizeof(cmd), "cp %s %s", CERT_TEST, CERT_PEM);
+        system(cmd);
+        snprintf(cmd, sizeof(cmd), "cp %s %s", CERT_TEST, CERT_CRT);
+        system(cmd);
+    } else
+        indigo_logger(LOG_LEVEL_INFO, "Do not configure root certificate!");
+
+
+    tlv = find_wrapper_tlv_by_id(req, TLV_AFC_SERVER_URL);
+    if (!tlv)
+        goto done;
+    memcpy(url, tlv->value, tlv->len);
+    snprintf(buffer, sizeof(buffer), "afcd -dB -u %s/availableSpectrumInquiry", url);
+    indigo_logger(LOG_LEVEL_INFO, "send_afc_req: %s", buffer);
+    system(buffer);
+
+    indigo_logger(LOG_LEVEL_INFO, "send_afc_req: killall hostapd");
+    system("killall hostapd");
+    sprintf(buffer, "%s -B -t -P /var/run/hostapd.pid -g %s %s -f /var/log/hostapd.log %s",
+        get_hapd_full_exec_path(),
+        get_hapd_global_ctrl_path(),
+        get_hostapd_debug_arguments(), 
+        get_all_hapd_conf_files(&swap_hostapd));
+    len = system(buffer);
+    sleep(1);
+    bridge_init(get_wlans_bridge());
+done:
+    fill_wrapper_message_hdr(resp, API_CMD_RESPONSE, req->hdr.seq);
+    fill_wrapper_tlv_byte(resp, TLV_STATUS, status);
+    fill_wrapper_tlv_bytes(resp, TLV_MESSAGE, strlen(message), message);
+    return 0;
+}
+
+
+static int afcd_operation_handler(struct packet_wrapper *req, struct packet_wrapper *resp) {
+    struct interface_info* wlan = NULL;
+    struct bss_identifier_info bss_info;
+    struct tlv_hdr *tlv;
+    size_t resp_len;
+    char *message = TLV_VALUE_OK;
+    char req_type[8];
+    char frame_bw[8];
+
+    tlv = find_wrapper_tlv_by_id(req, TLV_AFC_DEVICE_RESET);
+    if (tlv) {
+        indigo_logger(LOG_LEVEL_DEBUG, "Device reset");
+        restore_backup_certificate();
+        system("killall afcd 2> /dev/null && killall hostapd 2> /dev/null");
+    }
+
+    tlv = find_wrapper_tlv_by_id(req, TLV_AFC_SEND_SPECTRUM_REQ);
+    if (tlv) {
+        struct wpa_ctrl *w = NULL;
+        char request[S_BUFFER_LEN];
+        char response[S_BUFFER_LEN];
+
+        memset(req_type, 0, sizeof(req_type));
+        memcpy(req_type, tlv->value, tlv->len);
+        if (atoi(req_type) == 0) {
+            indigo_logger(LOG_LEVEL_DEBUG, "Send Spectrum request with Channel and Frequency based");
+        } else if (atoi(req_type) == 1) {
+            indigo_logger(LOG_LEVEL_DEBUG, "Send Spectrum request with Channel based");
+        } else if (atoi(req_type) == 2) {
+            indigo_logger(LOG_LEVEL_DEBUG, "Send Spectrum request with Frequency based");
+        }
+
+        /* Assemble hostapd command for rekey GTK */
+        memset(request, 0, sizeof(request));
+        sprintf(request, "AFC_SEND_REQUEST");
+        indigo_logger(LOG_LEVEL_INFO, "%s", request);
+
+        /* Open hostapd UDS socket */
+        w = wpa_ctrl_open(get_hapd_ctrl_path());
+        indigo_logger(LOG_LEVEL_INFO, "ctrl path %s", get_hapd_ctrl_path());
+        if (!w) {
+            indigo_logger(LOG_LEVEL_ERROR, "Failed to connect to hostapd");
+            goto fail;
+        }
+        resp_len = sizeof(response) - 1;
+        wpa_ctrl_request(w, request, strlen(request), response, &resp_len, NULL);
+        /* Check response */
+        if (strncmp(response, WPA_CTRL_OK, strlen(WPA_CTRL_OK)) != 0) {
+            indigo_logger(LOG_LEVEL_ERROR, "Failed to execute the command. Response: %s", response);
+            message = TLV_VALUE_HOSTAPD_RESP_NOT_OK;
+            goto fail;
+        }
+    }
+
+    tlv = find_wrapper_tlv_by_id(req, TLV_AFC_POWER_CYCLE);
+    if (tlv) {
+        indigo_logger(LOG_LEVEL_DEBUG, "Trigger power cycle");
+        restore_backup_certificate();
+        system("killall afcd && killall hostapd");
+    }
+
+    tlv = find_wrapper_tlv_by_id(req, TLV_AFC_SEND_TEST_FRAME);
+    if (tlv) {
+        memset(frame_bw, 0, sizeof(frame_bw));
+        memcpy(frame_bw, tlv->value, tlv->len);
+        if (atoi(frame_bw) == 0) {
+            indigo_logger(LOG_LEVEL_DEBUG, "Trigger DUT to send test frames for 20MHz bandwidth");
+        } else if (atoi(frame_bw) == 1) {
+            indigo_logger(LOG_LEVEL_DEBUG, "Trigger DUT to send test frames for 40MHz bandwidth");
+        } else if (atoi(frame_bw) == 2) {
+            indigo_logger(LOG_LEVEL_DEBUG, "Trigger DUT to send test frames for 80MHz bandwidth");
+        } else if (atoi(frame_bw) == 3) {
+            indigo_logger(LOG_LEVEL_DEBUG, "Trigger DUT to send test frames for 160MHz bandwidth");
+        }
+    }
+
+    tlv = find_wrapper_tlv_by_id(req, TLV_AFC_CONNECT_SP_AP);
+    if (tlv) {
+        indigo_logger(LOG_LEVEL_DEBUG, "Trigger AFC DUT to initiate connection procedure between AFC DUT and SP Access Point");
+        /* Vendor specific */
+    }
+
+    fill_wrapper_message_hdr(resp, API_CMD_RESPONSE, req->hdr.seq);
+    fill_wrapper_tlv_byte(resp, TLV_STATUS, TLV_VALUE_STATUS_OK);
+    fill_wrapper_tlv_bytes(resp, TLV_MESSAGE, strlen(TLV_VALUE_OK), TLV_VALUE_OK);
+    return 0;
+fail:
+    fill_wrapper_message_hdr(resp, API_CMD_RESPONSE, req->hdr.seq);
+    fill_wrapper_tlv_byte(resp, TLV_STATUS, TLV_VALUE_STATUS_NOT_OK);
+    fill_wrapper_tlv_bytes(resp, TLV_MESSAGE, strlen(message), message);
+    return 0;
+}
