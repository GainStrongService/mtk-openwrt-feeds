From 01cee82c93cf971d4d172e9a8af4eeb70cfa87cf Mon Mar 30 14:29:19 2026
From: Sky Huang <skylake.huang@mediatek.com>
Date: Mon, 30 Mar 2026 14:29:19 +0800
Subject: [PATCH] mediatek: filogic: patch-base: Add sysupgrade support for missing filogic RFBs

---
[v1] mediatek: filogic: patch-base: Add sysupgrade support for missing filogic RFBs

Add sysupgrade support for MT798x series RFB.

---
v1: Initial implementation.
---
--- a/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
+++ b/target/linux/mediatek/filogic/base-files/lib/upgrade/platform.sh
@@ -79,7 +79,15 @@ platform_do_upgrade() {
 
 	case "$board" in
 	mediatek,mt7981-rfb|\
-	mediatek,mt7988a-rfb)
+	mediatek,mt7986a-rfb|\
+	mediatek,mt7986a-rfb-snand|\
+	mediatek,mt7986a-rfb-snor|\
+	mediatek,mt7986b-rfb|\
+	mediatek,mt7987a|\
+	mediatek,mt7988a-rfb|\
+	mediatek,mt7988a-rfb-gsw|\
+	mediatek,mt7988d-rfb|\
+	mediatek,mt7988d-rfb-gsw)
 		[ -e /dev/dm-0 ] && dmsetup remove_all
 		[ -e /dev/fit0 ] && fitblk /dev/fit0
 		[ -e /dev/fitrw ] && fitblk /dev/fitrw
@@ -123,7 +131,15 @@ platform_do_upgrade() {
 	jdcloud,re-cp-03|\
 	konka,komi-a31|\
 	mediatek,mt7981-rfb|\
+	mediatek,mt7986a-rfb|\
+	mediatek,mt7986a-rfb-snand|\
+	mediatek,mt7986a-rfb-snor|\
+	mediatek,mt7986b-rfb|\
+	mediatek,mt7987a|\
 	mediatek,mt7988a-rfb|\
+	mediatek,mt7988a-rfb-gsw|\
+	mediatek,mt7988d-rfb|\
+	mediatek,mt7988d-rfb-gsw|\
 	mercusys,mr90x-v1-ubi|\
 	netis,nx30v2|\
 	netis,nx31|\
@@ -318,7 +334,15 @@ platform_check_image() {
 	jdcloud,re-cp-03|\
 	konka,komi-a31|\
 	mediatek,mt7981-rfb|\
+	mediatek,mt7986a-rfb|\
+	mediatek,mt7986a-rfb-snand|\
+	mediatek,mt7986a-rfb-snor|\
+	mediatek,mt7986b-rfb|\
+	mediatek,mt7987a|\
 	mediatek,mt7988a-rfb|\
+	mediatek,mt7988a-rfb-gsw|\
+	mediatek,mt7988d-rfb|\
+	mediatek,mt7988d-rfb-gsw|\
 	mercusys,mr90x-v1-ubi|\
 	nokia,ea0326gmp|\
 	openwrt,one|\
@@ -370,7 +394,15 @@ platform_copy_config() {
 	cmcc,rax3000m|\
 	gatonetworks,gdsp|\
 	mediatek,mt7981-rfb|\
-	mediatek,mt7988a-rfb)
+	mediatek,mt7986a-rfb|\
+	mediatek,mt7986a-rfb-snand|\
+	mediatek,mt7986a-rfb-snor|\
+	mediatek,mt7986b-rfb|\
+	mediatek,mt7987a|\
+	mediatek,mt7988a-rfb|\
+	mediatek,mt7988a-rfb-gsw|\
+	mediatek,mt7988d-rfb|\
+	mediatek,mt7988d-rfb-gsw)
 		if [ "$CI_METHOD" = "emmc" ]; then
 			emmc_copy_config
 		fi
