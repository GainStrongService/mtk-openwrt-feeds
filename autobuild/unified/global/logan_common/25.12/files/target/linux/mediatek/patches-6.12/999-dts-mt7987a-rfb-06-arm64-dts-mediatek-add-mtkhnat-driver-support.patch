diff --git a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-e2p5g.dtso b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-e2p5g.dtso
index be5858e..5d5018a 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-e2p5g.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-e2p5g.dtso
@@ -32,5 +32,12 @@ phy12: phy@12 {
 			};
 		};
 	};
+
+	fragment@2 {
+		target-path = "/soc_netsys/hnat@15000000";
+		__overlay__ {
+			mtketh-lan = "eth0";
+		};
+	};
 };
 
diff --git a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-mt7531-gsw.dtso b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-mt7531-gsw.dtso
index 1e26d96..33b40d3 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-mt7531-gsw.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-mt7531-gsw.dtso
@@ -80,4 +80,11 @@ fixed-link {
 			};
 		};
 	};
+
+	fragment@3 {
+		target-path = "/soc_netsys/hnat@15000000";
+		__overlay__ {
+			mtketh-lan = "eth0";
+		};
+	};
 };
diff --git a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-an8801sb.dtso b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-an8801sb.dtso
index a9f5d9b..0c68288 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-an8801sb.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-an8801sb.dtso
@@ -32,5 +32,13 @@ phy31: phy@31 {
 			};
 		};
 	};
+
+	fragment@2 {
+		target-path = "/soc_netsys/hnat@15000000";
+		__overlay__ {
+			mtketh-lan2 = "eth2";
+			mtketh-max-gmac = <3>;
+		};
+	};
 };
 
diff --git a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-e2p5g.dtso b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-e2p5g.dtso
index fc3b34a..183bb52 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-e2p5g.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-e2p5g.dtso
@@ -30,5 +30,13 @@ phy11: phy@11 {
 			};
 		};
 	};
+
+	fragment@2 {
+		target-path = "/soc_netsys/hnat@15000000";
+		__overlay__ {
+			mtketh-lan2 = "eth2";
+			mtketh-max-gmac = <3>;
+		};
+	};
 };
 
diff --git a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-sfp.dtso b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-sfp.dtso
index 75d3cf1..73321cd 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-sfp.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth2-sfp.dtso
@@ -41,5 +41,13 @@ __overlay__ {
 			status = "okay";
 		};
 	};
+
+	fragment@3 {
+		target-path = "/soc_netsys/hnat@15000000";
+		__overlay__ {
+			mtketh-lan2 = "eth2";
+			mtketh-max-gmac = <3>;
+		};
+	};
 };
 
diff --git a/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi b/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi
index abb3cdb..1eaeb04 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi
@@ -90,6 +90,16 @@ mdio: mdio-bus {
 		};
 	};
 
+	hnat: hnat@15000000 {
+		compatible = "mediatek,mtk-hnat_v5";
+		reg = <0 0x15100000 0 0x80000>;
+		interrupts = <GIC_SPI 198 IRQ_TYPE_LEVEL_HIGH>;
+		resets = <&ethsys 0>;
+		reset-names = "mtketh";
+		mtketh-soc = <&eth>;
+		status = "disabled";
+	};
+
 	crypto: crypto@15600000 {
 		compatible = "inside-secure,safexcel-eip197b",
 			     "security-ip-197-srv";
@@ -111,3 +121,11 @@ &crypto {
 &eth {
 	status = "okay";
 };
+
+&hnat {
+	mtketh-wan = "eth1";
+	mtketh-lan = "lan";
+	mtketh-max-gmac = <3>;
+	mtketh-ppe-num = <2>;
+	status = "okay";
+};
-- 
2.45.2

