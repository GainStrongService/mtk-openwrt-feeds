 };
 
diff --git a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-an8855-gsw.dtso b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-an8855-gsw.dtso
index d747bfd..b014e4c 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-an8855-gsw.dtso
+++ b/arch/arm64/boot/dts/mediatek/mt7987-netsys-eth0-an8855-gsw.dtso
