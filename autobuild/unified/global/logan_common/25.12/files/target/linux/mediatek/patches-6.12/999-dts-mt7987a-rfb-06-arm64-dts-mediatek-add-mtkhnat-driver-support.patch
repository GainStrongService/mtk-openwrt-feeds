From 8b069c3561f9aaad795b11e20d7424c3a131d0a9 Mon Sep 17 00:00:00 2001
From: "chak-kei.lam" <chak-kei.lam@mediatek.com>
Date: Thu, 4 Jun 2026 16:02:20 +0800
Subject: [PATCH] arm64: dts: mt7987-netsys: add mtkhnat driver support

---
 arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi | 18 ++++++++++++++++++
 1 file changed, 18 insertions(+)

diff --git a/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi b/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi
index abb3cdb..28b68fc 100644
--- a/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi
+++ b/arch/arm64/boot/dts/mediatek/mt7987-netsys.dtsi
@@ -90,6 +90,16 @@ mdio: mdio-bus {
 		};
 	};
 
+	hnat: hnat@15000000 {
+		compatible = "mediatek,mtk-hnat_v5";
+		reg = <0 0x15100000 0 0x80000>;
+		interrupts = <GIC_SPI 198 IRQ_TYPE_LEVEL_HIGH>;
+		resets = <&ethsys 0>;
+		reset-names = "mtketh";
+		mtketh-soc = <&eth>;
+		status = "disabled";
+	};
+
 	crypto: crypto@15600000 {
 		compatible = "inside-secure,safexcel-eip197b",
 			     "security-ip-197-srv";
@@ -111,3 +121,11 @@ &crypto {
 &eth {
 	status = "okay";
 };
+
+&hnat {
+	mtketh-wan = "eth1";
+	mtketh-lan = "lan";
+	mtketh-max-gmac = <3>;
+	mtketh-ppe-num = <2>;
+	status = "okay";
+};
-- 
2.45.2

