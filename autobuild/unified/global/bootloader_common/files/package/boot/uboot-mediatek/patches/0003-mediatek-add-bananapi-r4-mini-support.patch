From 245938b309757bce1303493d447c04b16ec5ff99 Mon Sep 17 00:00:00 2001
From: Sam Shih <sam.shih@mediatek.com>
Date: Wed, 4 Mar 2026 10:03:45 +0800
Subject: [PATCH] mediatek: add bananapi-r4-mini support

Add bananapi-bpi-r4-mini (MT7987A) support

ethernet:
AN8811HB + MT7987 Internal 2.5G PHY

flash:
spi2 nand + emmc

CR-Id: WCNCR00477741
Signed-off-by: Sam Shih <sam.shih@mediatek.com>
Change-Id: Icd6dc3cac642ac0d364629ed91168d2d05ca69a3
---
 arch/arm/dts/mt7987a-bananapi-bpi-r4-mini.dts |  51 ++++++++
 configs/bananapi_r4_mini_emmc_defconfig       | 122 ++++++++++++++++++
 .../bananapi_r4_mini_spim_nand_nmbm_defconfig | 108 ++++++++++++++++
 .../bananapi_r4_mini_spim_nand_ubi_defconfig  | 111 ++++++++++++++++
 4 files changed, 392 insertions(+)
 create mode 100644 arch/arm/dts/mt7987a-bananapi-bpi-r4-mini.dts
 create mode 100644 configs/bananapi_r4_mini_emmc_defconfig
 create mode 100644 configs/bananapi_r4_mini_spim_nand_nmbm_defconfig
 create mode 100644 configs/bananapi_r4_mini_spim_nand_ubi_defconfig

--- /dev/null
+++ b/arch/arm/dts/mt7987a-bananapi-bpi-r4-mini.dts
@@ -0,0 +1,46 @@
+// SPDX-License-Identifier: (GPL-2.0-only OR MIT)
+
+#include "mt7987a.dtsi"
+#include "mt7987-emmc.dtsi"
+#include "mt7987a-rfb-u-boot.dtsi"
+
+/ {
+	model = "mt7987";
+	compatible = "mediatek,mt7987", "bananapi,bpi-r4-mini";
+};
+
+&eth0 {
+	/delete-property/ mediatek,switch;
+	/delete-property/ reset-gpios;
+	phy-handle = <&phy14>;
+
+	phy14: eth-phy@14 {
+		compatible = "ethernet-phy-idc0ff.04a0";
+		reg = <14>;
+		phy-mode = "2500base-x";
+		reset-gpios = <&pio 42 GPIO_ACTIVE_LOW>;
+		reset-assert-us = <10000>;
+		reset-deassert-us = <10000>;
+		airoha,pnswap-rx;
+	};
+};
+
+&eth2 {
+	status = "disabled";
+};
+
+&spi0 {
+	status = "disabled";
+};
+
+&spi2 {
+	/delete-node/ spi_nor@0;
+	spi_nand@0 {
+		compatible = "spi-nand";
+		reg = <0>;
+		spi-max-frequency = <52000000>;
+		spi-rx-bus-width = <4>;
+		spi-tx-bus-width = <4>;
+	};
+};
+
