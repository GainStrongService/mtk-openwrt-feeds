From ed6924828479aaeadbb7c402ec390df26dcbd8bc Mon Sep 17 00:00:00 2001
From: Peter Chiu <chui-hao.chiu@mediatek.com>
Date: Tue, 7 Jul 2026 16:28:19 +0800
Subject: [PATCH] mtk: mt76: mt7996: Put unexpected packets to ALTXQ

Problem:
If AP send deauth or disassoc to peer station when
station is in power saving mode, deauth or disassoc
may queue in ACQ and lead to PLE hang.

Root Cause:
TXD cannot be transmitted because station is PSM.

Solution:
Put disassoc and packets to unauthorized stations to ALTXQ.

Feature:
TRx Path

Signed-off-by: Peter Chiu <chui-hao.chiu@mediatek.com>
---
 mt7996/mac.c  | 2 +-
 mt7996/main.c | 9 +++++++++
 tx.c          | 3 ++-
 3 files changed, 12 insertions(+), 2 deletions(-)

diff --git a/mt7996/mac.c b/mt7996/mac.c
index 51b7240da..fe91b0c49 100644
--- a/mt7996/mac.c
+++ b/mt7996/mac.c
@@ -933,7 +933,7 @@ void mt7996_mac_write_txwi(struct mt7996_dev *dev, __le32 *txwi,
 	} else if (beacon) {
 		p_fmt = MT_TX_TYPE_FW;
 		q_idx = MT_LMAC_BCN0;
-	} else if (qid >= MT_TXQ_PSD) {
+	} else if (qid >= MT_TXQ_PSD || (!(wcid->tx_info & MT_WCID_TX_INFO_SET))) {
 		p_fmt = MT_TX_TYPE_CT;
 		q_idx = MT_LMAC_ALTX0;
 	} else {
diff --git a/mt7996/main.c b/mt7996/main.c
index 050dc8a95..88ca83a58 100644
--- a/mt7996/main.c
+++ b/mt7996/main.c
@@ -1605,6 +1605,15 @@ mt7996_mac_sta_event(struct mt7996_dev *dev, struct ieee80211_vif *vif,
 		}
 		break;
 	case MT76_STA_EVENT_DISASSOC:
+		for_each_set_bit(link_id, &add, IEEE80211_MLD_MAX_NUM_LINKS) {
+			struct mt7996_sta_link *msta_link =
+				mt76_dereference(msta->link[link_id], &dev->mt76);
+
+			if (!msta_link)
+				continue;
+
+			msta_link->wcid.tx_info &= ~MT_WCID_TX_INFO_SET;
+		}
 		ieee80211_iterate_stations_atomic(dev->mt76.hw, mt7996_check_mld_sta,
 						  &has_mld_sta);
 		if (!has_mld_sta)
diff --git a/tx.c b/tx.c
index dfbb5ef98..d0f8ca9dd 100644
--- a/tx.c
+++ b/tx.c
@@ -643,7 +643,8 @@ mt76_txq_schedule_pending_wcid(struct mt76_phy *phy, struct mt76_wcid *wcid,
 		    !(info->flags & IEEE80211_TX_CTL_HW_80211_ENCAP) &&
 		    !ieee80211_is_data(hdr->frame_control) &&
 		    (!ieee80211_is_bufferable_mmpdu(skb) ||
-		     ieee80211_is_deauth(hdr->frame_control)))
+		     ieee80211_is_deauth(hdr->frame_control) ||
+		     ieee80211_is_disassoc(hdr->frame_control)))
 			qid = MT_TXQ_PSD;
 
 		q = phy->q_tx[qid];
-- 
