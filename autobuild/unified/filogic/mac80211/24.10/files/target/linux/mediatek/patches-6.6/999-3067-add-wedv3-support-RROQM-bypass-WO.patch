From e336e92ab95d199f23a3b2447d6dce06fe602769 Mon Sep 17 00:00:00 2001
From: Rex Lu <rex.lu@mediatek.com>
Date: Wed, 11 Mar 2026 14:52:49 +0800
Subject: [PATCH] add wedv3 support RROQM bypass WO

Signed-off-by: Rex Lu <rex.lu@mediatek.com>
---
 drivers/net/ethernet/mediatek/mtk_wed.c      | 9 +++++++++
 drivers/net/ethernet/mediatek/mtk_wed_regs.h | 3 +++
 2 files changed, 12 insertions(+)

diff --git a/drivers/net/ethernet/mediatek/mtk_wed.c b/drivers/net/ethernet/mediatek/mtk_wed.c
index a09e5d5..50d6ef0 100644
--- a/drivers/net/ethernet/mediatek/mtk_wed.c
+++ b/drivers/net/ethernet/mediatek/mtk_wed.c
@@ -1565,6 +1565,10 @@ mtk_wed_rro_hw_init(struct mtk_wed_device *dev)
 
 	wed_w32(dev, MTK_WED_RROQM_RST_IDX, 0);
 	wed_w32(dev, MTK_WED_RROQM_MIOD_CTRL2, MTK_WED_MIOD_CNT - 1);
+
+	if (mtk_wed_is_v3(dev->hw))
+		wed_set(dev, MTK_WED_RROQM_GLO_CFG, MTK_WED_RROQM_GLO_CFG_BYPASS);
+
 	wed_set(dev, MTK_WED_CTRL, MTK_WED_CTRL_RX_RRO_QM_EN);
 }
 
@@ -1592,6 +1596,11 @@ mtk_wed_route_qm_hw_init(struct mtk_wed_device *dev)
 			FIELD_PREP(MTK_WED_RTQM_ENQ_CFG_TXDMAD_FPORT,
 				   0x3 + dev->hw->index));
 	}
+
+	if (mtk_wed_is_v3(dev->hw))
+		wed_set(dev, MTK_WED_RTQM_IGRS1_CFG0,
+			FIELD_PREP(MTK_WED_RTQM_IGRS1_CFG0_DEST_FORCE, 0x2));
+
 	/* enable RX_ROUTE_QM */
 	wed_set(dev, MTK_WED_CTRL, MTK_WED_CTRL_RX_ROUTE_QM_EN);
 }
diff --git a/drivers/net/ethernet/mediatek/mtk_wed_regs.h b/drivers/net/ethernet/mediatek/mtk_wed_regs.h
index 54c5333..0421956 100644
--- a/drivers/net/ethernet/mediatek/mtk_wed_regs.h
+++ b/drivers/net/ethernet/mediatek/mtk_wed_regs.h
@@ -578,6 +578,8 @@ struct mtk_wdma_desc {
 #define MTK_WED_RTQM_IGRS0_I2H_PKT_CNT(_n)		(0xb2c + (_n) * 0x4)
 #define MTK_WED_RTQM_IGRS0_FDROP_CNT			0xb34
 
+#define MTK_WED_RTQM_IGRS1_CFG0				0xb3c
+#define MTK_WED_RTQM_IGRS1_CFG0_DEST_FORCE		GENMASK(2, 0)
 #define MTK_WED_RTQM_IGRS1_I2HW_DMAD_CNT		0xb44
 #define MTK_WED_RTQM_IGRS1_I2H_DMAD_CNT(_n)		(0xb48 + (_n) * 0x4)
 #define MTK_WED_RTQM_IGRS1_I2HW_PKT_CNT			0xb50
@@ -623,6 +625,7 @@ struct mtk_wdma_desc {
 #define MTK_WED_RTQM_DEQ_ERR_CNT			0xbec
 
 #define MTK_WED_RROQM_GLO_CFG				0xc04
+#define MTK_WED_RROQM_GLO_CFG_BYPASS			BIT(24)
 #define MTK_WED_RROQM_RST_IDX				0xc08
 #define MTK_WED_RROQM_RST_IDX_MIOD			BIT(0)
 #define MTK_WED_RROQM_RST_IDX_FDBK			BIT(4)
-- 
2.45.2

