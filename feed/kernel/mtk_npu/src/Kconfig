config MTK_NPU_SUPPORT
	bool "Mediatek Network Processor Unit Support"
	help
	  Support for Mediatek Network Processor Unit which offloads network
	  operations from APMCU. The subsystem supports tunnel protocols
	  offload, such as GRE, VxLAN, L2TP, PPTP etc., and other network
	  features, such as multicast, L4S, from host CPU.

config MTK_NPU_GRE
	depends on MTK_NPU_SUPPORT
	bool
	help
	  Support for GRE offload to Mediatek Network Processor Unit.
	  Alleviate host CPU's loading by offloading GRE related encapulation
	  and decapulation to NPU.

config MTK_NPU_GRETAP
	depends on MTK_NPU_SUPPORT
	select MTK_NPU_GRE
	bool "Mediatek NPU L2oGRE Offload Support"
	help
	  Support for L2oGRE offload to Mediatek Network Processor Unit.
	  Alleviate host CPU's loading by offloading L2oGRE encapulation and
	  decapulation to NPU.

config MTK_NPU_PPTP
	depends on MTK_NPU_SUPPORT
