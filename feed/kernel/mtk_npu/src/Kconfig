config NPU_TNL_NUM
	int "Mediatek NPU Tunnel Count"
	depends on MTK_NPU_SUPPORT
	help
	  Configuration for tunnel count for Network Processor Unit.
	  This value should be 2 ^ NPU_TNL_MAP_BIT.

config NPU_TNL_MAP_BIT
	int "Mediatek NPU Tunnel Map Bit"
	depends on MTK_NPU_SUPPORT
	help
	  Configuration for tunnel map bit for Network Processor Unit.
	  This value is log of NPU_TNL_NUM.

config NPU_FLOW_NUM
	int "Mediatek NPU Flow Count"
	depends on MTK_NPU_SUPPORT
	help
	  Configuration for flow count for Network Processor Unit.

config MTK_NPU_FLOW
	bool
	help
	 Configuration for flow feature for Network Processor Unit

config MTK_NPU_IAP_SUPPORT
	bool
	help
	 Configuration for MediaTek NPU support for IAP applications.

config MTK_NPU_CCN71_SUPPORT
	bool
	help
	 Configuration for MediaTek NPU support for CCN71 applications.

config MTK_NPU_SELECT_NETSYS_PATH_MODE_SUPPORT
	bool
	help
	 Configuration for NPU support for selecting netsys path mode.
