START=19

USE_PROCD=1
NAME=mtkhnat
PROG=/sbin/mtkhnat

start_service() {
	procd_open_instance
	procd_set_param command "${PROG}"
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "mtkhnat"
}
